# Copy to the repo root as `.env` and fill in values. Never commit `.env`.
#
# dbt, scraper, Airflow, and the backend all read from this file when run locally
# (see `backend/src/loadEnv.js`, `scraper/scrape_liverpool.py`, `frontend/vite.config.js`).

# --- Google Cloud (BigQuery) ---
GCP_PROJECT=

# Artifact Registry host + project + repository path (e.g. europe-west1-docker.pkg.dev/YOUR_PROJECT/liverpool)
REGISTRY=

# Public site / TLS (Nginx `server_name`, Let's Encrypt path; can be a domain or a VM public IP)
DOMAIN=

# Public browser origin for CORS when running the API locally (production Docker uses https://${DOMAIN} from docker-compose)
FRONTEND_URL=

# Data season code used by the scraper, API defaults, and Airflow (e.g. 2425 for 2024-25)
CURRENT_SEASON=

# Must match `CURRENT_SEASON` for the Vite build; exposed to the browser (not secret)
VITE_SEASON=

# OpenAI
OPENAI_API_KEY=

# Airflow
AIRFLOW_SECRET=

# Optional: your GitHub username (e.g. for personal notes; not read by the app)
GITHUB_USERNAME=
